{
  "name": "libsonare-homepage",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.15.0",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "copy:wasm": "./scripts/copy-wasm.sh",
    "generate:demos": "node scripts/generate-demo-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ncu": "NO_UPDATE_NOTIFIER=1 ncu",
    "ncu:update": "NO_UPDATE_NOTIFIER=1 ncu -u",
    "check": "yarn check:docs && yarn check:glossary && yarn check:i18n && yarn check:demos && yarn check:mastering-docs && yarn check:mastering",
    "verify": "yarn check && yarn test && yarn build && yarn check:built-routes",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:glossary": "node scripts/check-glossary-coverage.mjs",
    "check:i18n": "node scripts/check-i18n-parity.mjs",
    "check:demos": "node scripts/check-demos.mjs",
    "check:mastering-docs": "node scripts/check-mastering-docs.mjs",
    "check:built-routes": "node scripts/check-built-routes.mjs",
    "check:mastering": "node scripts/validate-mastering-presets.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@vitejs/plugin-vue": "^6",
    "@vue/compiler-dom": "^3.5",
    "@vue/test-utils": "^2.4",
    "jsdom": "^29",
    "npm-check-updates": "^22.2.7",
    "typescript": "^6.0.3",
    "vite": "^8",
    "vitepress": "^1.6.4",
    "vitest": "^4",
    "vue": "^3.5.39"
  },
  "volta": {
    "node": "22.22.3",
    "yarn": "4.15.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "mermaid": "^11.16.0",
    "three": "^0.185.0",
    "vexflow": "^5",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
